# SpendWise Server Environment Configuration
PORT=5000
MONGO_URI=mongodb://localhost:27017/spendwise

# Groq LLM assistant configuration
# Add your Groq API key here.
# If your environment requires a custom endpoint, set GROQ_API_URL.
# Example: GROQ_API_URL=https://api.groq.ai/v1/outputs
GROQ_API=
GROQ_API_URL=https://api.groq.ai/v1/outputs
GROQ_MODEL=llama-3.1-8b-instant
